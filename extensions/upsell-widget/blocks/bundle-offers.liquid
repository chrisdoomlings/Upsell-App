{{ 'bundle-offers.css' | asset_url | stylesheet_tag }}

<div
id="upsale-bundle-offers-root"
data-shop="{{ shop.permanent_domain }}"
data-currency="{{ shop.currency }}"
data-api-base="https://upseller-app.vercel.app"
data-code-note="{{ settings.code_note | default: 'Bundle discount applied: [code]' | escape }}"
></div>

<script src="{{ 'bundle-offers.js' | asset_url }}" defer></script>

{% schema %}
{
"name": "Bundle offers",
"target": "body",
"settings": [
{
"type": "text",
"id": "code_note",
"label": "Code note",
"default": "Bundle discount applied: [code]"
}
]
}
{% endschema %}
