{% comment %} Upsale - Buy X Get Y Gift Automation {% endcomment %}

<div
id="upsale-bxgy-root"
data-shop="{{ shop.permanent_domain }}"
data-api-base="{{ settings.api_base | default: 'https://doomling-app-navy.vercel.app' }}"
data-toast-title="{{ settings.toast_title | default: 'Free gift added!' | escape }}"
data-banner-title="{{ settings.banner_title | default: 'Your free gift is in the cart' | escape }}"
></div>

<style>
#upsale-bxgy-floating {
position: fixed;
right: 1.25rem;
bottom: 1.25rem;
z-index: 99998;
width: min(340px, calc(100vw - 1.5rem));
display: none;
border-radius: 18px;
overflow: hidden;
background: linear-gradient(135deg, #14532d 0%, #166534 48%, #22c55e 100%);
color: #fff;
box-shadow: 0 18px 48px rgba(21, 128, 61, 0.28);
font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
}
#upsale-bxgy-floating * { box-sizing: border-box; }
#upsale-bxgy-floating-header {
display: flex;
align-items: center;
justify-content: space-between;
gap: 0.75rem;
padding: 0.9rem 1rem 0.65rem;
}
#upsale-bxgy-floating-title {
font-size: 0.9rem;
font-weight: 800;
letter-spacing: 0.02em;
}
#upsale-bxgy-floating-badge {
border-radius: 999px;
background: rgba(255,255,255,0.16);
padding: 0.25rem 0.55rem;
font-size: 0.68rem;
font-weight: 800;
letter-spacing: 0.08em;
}
#upsale-bxgy-floating-body {
background: rgba(255,255,255,0.1);
backdrop-filter: blur(10px);
padding: 0.9rem 1rem 1rem;
}
.upsale-bxgy-gift-row {
display: flex;
align-items: center;
gap: 0.75rem;
}
.upsale-bxgy-gift-row + .upsale-bxgy-gift-row {
margin-top: 0.7rem;
}
.upsale-bxgy-gift-image,
.upsale-bxgy-gift-placeholder {
width: 52px;
height: 52px;
border-radius: 14px;
flex-shrink: 0;
object-fit: cover;
border: 1px solid rgba(255,255,255,0.18);
}
.upsale-bxgy-gift-placeholder {
display: flex;
align-items: center;
justify-content: center;
background: rgba(255,255,255,0.16);
font-size: 1.1rem;
}
.upsale-bxgy-gift-text {
min-width: 0;
flex: 1;
}
.upsale-bxgy-gift-name {
display: block;
font-size: 0.85rem;
font-weight: 700;
white-space: nowrap;
overflow: hidden;
text-overflow: ellipsis;
}
.upsale-bxgy-gift-sub {
display: block;
margin-top: 0.15rem;
font-size: 0.76rem;
opacity: 0.9;
}
#upsale-bxgy-toast {
position: fixed;
left: 50%;
bottom: 1.25rem;
transform: translate(-50%, calc(100% + 2rem));
opacity: 0;
z-index: 99999;
width: min(360px, calc(100vw - 1.5rem));
border-radius: 18px;
padding: 0.95rem 1rem;
background: #ffffff;
border: 1px solid #bbf7d0;
box-shadow: 0 12px 34px rgba(0,0,0,0.16);
transition: transform 0.35s cubic-bezier(0.22, 1, 0.36, 1), opacity 0.2s ease;
font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
}
#upsale-bxgy-toast.upsale-bxgy-toast-visible {
transform: translate(-50%, 0);
opacity: 1;
}
#upsale-bxgy-toast-title {
margin: 0;
font-size: 0.9rem;
font-weight: 800;
color: #166534;
}
#upsale-bxgy-toast-text {
margin: 0.25rem 0 0;
font-size: 0.78rem;
color: #4b5563;
}
quantity-selector-component[data-upsale-bxgy-locked='true'] {
display: none !important;
pointer-events: none;
}
.upsale-bxgy-lock-note {
display: block;
margin-top: 0.45rem;
color: #166534;
font-size: 0.8rem;
font-weight: 600;
line-height: 1.35;
}
@media (max-width: 640px) {
#upsale-bxgy-floating {
left: 0.75rem;
right: 0.75rem;
width: auto;
bottom: 0.75rem;
}
#upsale-bxgy-toast {
bottom: 0.75rem;
}
}
</style>

<div id="upsale-bxgy-floating" aria-live="polite" aria-atomic="true">
<div id="upsale-bxgy-floating-header">
<span id="upsale-bxgy-floating-title">{{ settings.banner_title | default: 'Your free gift is in the cart' }}</span>
<span id="upsale-bxgy-floating-badge">FREE</span>
</div>
<div id="upsale-bxgy-floating-body"></div>
</div>

<div id="upsale-bxgy-toast" role="status" aria-live="polite" aria-atomic="true">
<p id="upsale-bxgy-toast-title">{{ settings.toast_title | default: 'Free gift added!' }}</p>
<p id="upsale-bxgy-toast-text"></p>
</div>

<script>
(function () {
var root = document.getElementById('upsale-bxgy-root');
if (!root) return;

var shop = root.dataset.shop || '';
var apiBase = (root.dataset.apiBase || '').replace(/\/$/, '');
var toastTitle = root.dataset.toastTitle || 'Free gift added!';
var floatingTitle = root.dataset.bannerTitle || 'Your free gift is in the cart';
var GIFT_FLAG = '_bxgy';
var RULE_FLAG = '_bxgy_rule_id';
var DISMISSED_FLAG = 'upsale_bxgy_dismissed';
var DISMISSED_TTL_MS = 30 * 60 * 1000;
var nativeFetch = window.fetch.bind(window);

if (!shop || !apiBase) return;

var rulesCache = null;
var rulesPromise = null;
var syncPending = false;
var syncRunning = false;
var latestCart = null;
var seenToasts;
var dismissedGifts;
try {
seenToasts = new Set(JSON.parse(sessionStorage.getItem('upsale_bxgy_seen') || '[]'));
} catch (e) {
seenToasts = new Set();
}
try {
dismissedGifts = JSON.parse(sessionStorage.getItem(DISMISSED_FLAG) || '{}') || {};
} catch (e) {
dismissedGifts = {};
}

function rememberToast(key) {
seenToasts.add(key);
try {
sessionStorage.setItem('upsale_bxgy_seen', JSON.stringify(Array.from(seenToasts)));
} catch (e) {}
}

function giftKey(ruleId, variantId) {
return String(ruleId) + ':' + String(variantId);
}

function persistDismissedGifts() {
try {
sessionStorage.setItem(DISMISSED_FLAG, JSON.stringify(dismissedGifts));
} catch (e) {}
}

function clearDismissedGift(ruleId, variantId) {
var key = giftKey(ruleId, variantId);
if (!dismissedGifts[key]) return;
delete dismissedGifts[key];
persistDismissedGifts();
}

function dismissGift(ruleId, variantId, buyQty) {
dismissedGifts[giftKey(ruleId, variantId)] = {
buyQty: Math.max(Number(buyQty) || 0, 0),
dismissedAt: Date.now()
};
persistDismissedGifts();
}

function pruneDismissedGifts() {
var now = Date.now();
var changed = false;
Object.keys(dismissedGifts).forEach(function (key) {
var entry = dismissedGifts[key];
if (!entry || typeof entry !== 'object') {
delete dismissedGifts[key];
changed = true;
return;
}

var dismissedAt = Number(entry.dismissedAt || 0);
if (!dismissedAt || (now - dismissedAt) > DISMISSED_TTL_MS) {
delete dismissedGifts[key];
changed = true;
}
});

if (changed) {
persistDismissedGifts();
}
}

function isGiftDismissed(ruleId, variantId, buyQty) {
var key = giftKey(ruleId, variantId);
var entry = dismissedGifts[key];
if (!entry || typeof entry !== 'object') return false;

var dismissedAt = Number(entry.dismissedAt || 0);
if (!dismissedAt || (Date.now() - dismissedAt) > DISMISSED_TTL_MS) {
clearDismissedGift(ruleId, variantId);
return false;
}

var dismissedBuyQty = Math.max(Number(entry.buyQty) || 0, 0);
var normalizedBuyQty = Math.max(Number(buyQty) || 0, 0);
if (dismissedBuyQty !== normalizedBuyQty) {
clearDismissedGift(ruleId, variantId);
return false;
}

return normalizedBuyQty > 0;
}

function loadRules() {
if (rulesCache) return Promise.resolve(rulesCache);
if (rulesPromise) return rulesPromise;
rulesPromise = nativeFetch(apiBase + '/api/public/gift-rules?shop=' + encodeURIComponent(shop), {
method: 'GET',
mode: 'cors',
credentials: 'omit',
cache: 'no-store'
}).then(function (r) {
return r.ok ? r.json() : { rules: [] };
}).then(function (data) {
rulesCache = (data && data.rules) || [];
return rulesCache;
}).catch(function () {
rulesCache = [];
return rulesCache;
});
return rulesPromise;
}

function fetchCart() {
return nativeFetch('/cart.js', { cache: 'no-store' }).then(function (r) { return r.json(); });
}

function getCartSectionIds() {
var sections = [];
document.querySelectorAll('cart-items-component[data-section-id], cart-discount[data-section-id]').forEach(function (element) {
if (!(element instanceof HTMLElement)) return;
var sectionId = element.dataset.sectionId;
if (sectionId && sections.indexOf(sectionId) === -1) {
sections.push(sectionId);
}
});
return sections;
}

function dispatchCartUpdate(payload) {
document.dispatchEvent(new CustomEvent('cart:update', {
bubbles: true,
detail: {
resource: {},
sourceId: 'upsale-bxgy-widget',
data: payload || {}
}
}));
}

function post(path, payload) {
var body = Object.assign({}, payload || {});
var sections = getCartSectionIds();
if (sections.length) {
body.sections = sections;
body.sections_url = window.location.pathname;
}

return nativeFetch(path, {
method: 'POST',
headers: {
'Content-Type': 'application/json',
Accept: 'application/json'
},
body: JSON.stringify(body)
}).then(function (r) { return r.ok ? r.json() : null; }).then(function (data) {
if (data && data.sections) {
dispatchCartUpdate({
source: 'upsale-bxgy-widget',
sections: data.sections
});
}
return data;
});
}

function track(ruleId, event) {
nativeFetch(apiBase + '/api/bxgy-track', {
method: 'POST',
headers: { 'Content-Type': 'application/json' },
body: JSON.stringify({ shop: shop, ruleId: ruleId, event: event })
}).catch(function () {});
}

function totalQtyByVariants(cart, variantIds) {
var ids = new Set((variantIds || []).map(String));
return ((cart && cart.items) || []).reduce(function (sum, item) {
var props = item && item.properties ? item.properties : {};
if (String(props[GIFT_FLAG] || '') === 'true') return sum;
return ids.has(String(item.variant_id)) ? sum + Number(item.quantity || 0) : sum;
}, 0);
}

function totalQtyAnyProduct(cart, giftVariantId) {
return ((cart && cart.items) || []).reduce(function (sum, item) {
var props = item && item.properties ? item.properties : {};
if (String(props[GIFT_FLAG] || '') === 'true') return sum;
if (giftVariantId && String(item.variant_id) === String(giftVariantId)) return sum;
return sum + Number(item.quantity || 0);
}, 0);
}

function getBuyQty(cart, rule) {
if (rule && rule.appliesToAnyProduct) {
return totalQtyAnyProduct(cart, rule.giftVariantId);
}
return totalQtyByVariants(cart, rule.buyVariantIds);
}

function findAutoGiftLine(cart, variantId, ruleId) {
var items = (cart && cart.items) || [];
for (var i = 0; i < items.length; i++) {
var item = items[i];
if (String(item.variant_id) !== String(variantId)) continue;
var props = item.properties || {};
if (String(props[GIFT_FLAG] || '') !== 'true') continue;
if (String(props[RULE_FLAG] || '') !== String(ruleId)) continue;
return item;
}
return null;
}

function hasManualGift(cart, variantId) {
var items = (cart && cart.items) || [];
for (var i = 0; i < items.length; i++) {
var item = items[i];
if (String(item.variant_id) !== String(variantId)) continue;
var props = item.properties || {};
if (String(props[GIFT_FLAG] || '') === 'true') continue;
return true;
}
return false;
}

function updateDismissedGifts(prevCart, nextCart, rules) {
if (!prevCart || !Array.isArray(rules) || !rules.length) return;

rules.forEach(function (rule) {
if (!rule || !rule.giftVariantId || (!rule.appliesToAnyProduct && (!rule.buyVariantIds || !rule.buyVariantIds.length))) return;

var buyQty = getBuyQty(nextCart, rule);
var bundleCount = Math.floor(buyQty / Math.max(Number(rule.buyQuantity || 1), 1));
var nextGiftLine = findAutoGiftLine(nextCart, rule.giftVariantId, rule.ruleId);
var prevGiftLine = findAutoGiftLine(prevCart, rule.giftVariantId, rule.ruleId);
var manualGift = hasManualGift(nextCart, rule.giftVariantId);

if (bundleCount <= 0 || nextGiftLine || manualGift) {
clearDismissedGift(rule.ruleId, rule.giftVariantId);
return;
}

if (prevGiftLine && !nextGiftLine) {
dismissGift(rule.ruleId, rule.giftVariantId, buyQty);
}
});
}

function showToast(title) {
var toast = document.getElementById('upsale-bxgy-toast');
var text = document.getElementById('upsale-bxgy-toast-text');
if (!toast || !text) return;
text.textContent = title + ' was added to the cart automatically.';
toast.classList.add('upsale-bxgy-toast-visible');
setTimeout(function () {
toast.classList.remove('upsale-bxgy-toast-visible');
}, 3200);
}

function renderFloating(gifts) {
var floating = document.getElementById('upsale-bxgy-floating');
var title = document.getElementById('upsale-bxgy-floating-title');
var body = document.getElementById('upsale-bxgy-floating-body');
if (!floating || !title || !body) return;
if (!gifts.length) {
floating.style.display = 'none';
return;
}

title.textContent = floatingTitle;
body.innerHTML = gifts.map(function (gift) {
var image = gift.featured_image && gift.featured_image.url
? '<img class="upsale-bxgy-gift-image" src="' + gift.featured_image.url.split('?')[0] + '?width=120" alt="" loading="lazy" width="52" height="52" />'
: '<div class="upsale-bxgy-gift-placeholder">&#127873;</div>';
return (
'<div class="upsale-bxgy-gift-row">' +
image +
'<div class="upsale-bxgy-gift-text">' +
'<span class="upsale-bxgy-gift-name">' + (gift.product_title || 'Free gift') + '</span>' +
'<span class="upsale-bxgy-gift-sub">Added automatically and discounted to free at checkout.</span>' +
'</div>' +
'</div>'
);
}).join('');
floating.style.display = 'block';
}

function refreshTheme() {
document.dispatchEvent(new CustomEvent('cart:refresh'));
document.dispatchEvent(new CustomEvent('cart:updated'));
}

function getGiftLockQuantityByLine(cart, line) {
if (!cart || !Array.isArray(cart.items) || !line) return 0;
var item = cart.items[line - 1];
if (!item || !item.properties || String(item.properties[GIFT_FLAG] || '') !== 'true') return 0;

return Math.max(Number(item.quantity || 0), 0);
}

function resetGiftSelector(selector) {
if (!(selector instanceof HTMLElement)) return;

var input = selector.querySelector('input[ref="quantityInput"], .quantity-input');
var buttons = selector.querySelectorAll('button[ref="quantityButtons[]"], .quantity-button');
var row = selector.closest('tr[data-key], tr[data-product-id]');

delete selector.dataset.upsaleBxgyLocked;
delete selector.dataset.lockedQuantity;

if (input instanceof HTMLInputElement) {
input.readOnly = false;
input.disabled = false;
input.removeAttribute('aria-disabled');
}

buttons.forEach(function (button) {
if (button instanceof HTMLButtonElement) {
button.hidden = false;
button.disabled = false;
}
});

if (row instanceof HTMLElement) {
var note = row.querySelector('.upsale-bxgy-lock-note');
if (note instanceof HTMLElement) {
note.remove();
}
}
}

function lockGiftSelector(selector, quantity) {
if (!(selector instanceof HTMLElement) || !quantity) return;

var input = selector.querySelector('input[ref="quantityInput"], .quantity-input');
var buttons = selector.querySelectorAll('button[ref="quantityButtons[]"], .quantity-button');
var row = selector.closest('tr[data-key], tr[data-product-id]');

selector.dataset.upsaleBxgyLocked = 'true';
selector.dataset.lockedQuantity = String(quantity);

if (input instanceof HTMLInputElement) {
input.value = String(quantity);
input.readOnly = true;
input.disabled = true;
input.setAttribute('aria-disabled', 'true');
}

buttons.forEach(function (button) {
if (button instanceof HTMLButtonElement) {
button.hidden = true;
button.disabled = true;
}
});

if (row instanceof HTMLElement) {
var quantityCell = row.querySelector('.cart-items__quantity .flex');
if (quantityCell instanceof HTMLElement) {
var note = row.querySelector('.upsale-bxgy-lock-note');
if (!(note instanceof HTMLElement)) {
note = document.createElement('small');
note.className = 'upsale-bxgy-lock-note';
quantityCell.appendChild(note);
}
note.textContent = 'Free gift';
}
}
}

function applyGiftGuards(cart) {
var selectors = document.querySelectorAll('quantity-selector-component');
selectors.forEach(function (selector) {
resetGiftSelector(selector);
});

selectors.forEach(function (selector) {
if (!(selector instanceof HTMLElement)) return;
var input = selector.querySelector('input[ref="quantityInput"], .quantity-input');
var line = input instanceof HTMLInputElement ? Number(input.dataset.cartLine || 0) : 0;
if (!line) return;

var quantity = getGiftLockQuantityByLine(cart, line);
if (!quantity) return;

lockGiftSelector(selector, quantity);
});
}

function sync(cart, rules) {
if (!Array.isArray(rules) || !rules.length) return Promise.resolve(false);

var actions = [];
var trackedQualification = false;

rules.forEach(function (rule) {
if (!rule || !rule.giftVariantId || (!rule.appliesToAnyProduct && (!rule.buyVariantIds || !rule.buyVariantIds.length))) return;

var buyQty = getBuyQty(cart, rule);
var giftLine = findAutoGiftLine(cart, rule.giftVariantId, rule.ruleId);
var manualGift = hasManualGift(cart, rule.giftVariantId);
var bundleCount = Math.floor(buyQty / Math.max(Number(rule.buyQuantity || 1), 1));
if (bundleCount <= 0) {
clearDismissedGift(rule.ruleId, rule.giftVariantId);
}
var scaledGiftQty = bundleCount * Math.max(Number(rule.giftQuantity || 1), 1);
var cappedGiftQty = buyQty >= Math.max(Number(rule.buyQuantity || 1), 1) ? Math.max(Number(rule.giftQuantity || 1), 1) : 0;
var desiredQty = (manualGift || isGiftDismissed(rule.ruleId, rule.giftVariantId, buyQty))
? 0
: (rule.limitOneGiftPerOrder ? cappedGiftQty : scaledGiftQty);

if (bundleCount > 0 && !trackedQualification) {
track(rule.ruleId, 'qualified');
trackedQualification = true;
}

if (!giftLine && desiredQty > 0) {
actions.push(function () {
track(rule.ruleId, 'auto_added');
return post('/cart/add.js', {
id: rule.giftVariantId,
quantity: desiredQty,
properties: {
_bxgy: 'true',
_bxgy_rule_id: String(rule.ruleId)
}
}).then(function () {
var key = String(rule.ruleId) + ':' + String(rule.giftVariantId);
if (!seenToasts.has(key)) {
rememberToast(key);
showToast(rule.giftTitle || 'Free gift');
}
});
});
return;
}

if (giftLine && desiredQty === 0) {
actions.push(function () {
return post('/cart/change.js', { id: giftLine.key, quantity: 0 });
});
return;
}

if (giftLine && desiredQty > 0 && Number(giftLine.quantity || 0) !== desiredQty) {
actions.push(function () {
return post('/cart/change.js', { id: giftLine.key, quantity: desiredQty });
});
}
});

if (!actions.length) return Promise.resolve(false);

var chain = Promise.resolve();
actions.forEach(function (action) {
chain = chain.then(function () { return action(); }).catch(function () { return null; });
});
return chain.then(function () { return true; });
}

function runSync() {
if (syncRunning) {
syncPending = true;
return;
}
pruneDismissedGifts();
syncRunning = true;
Promise.all([fetchCart(), loadRules()]).then(function (payload) {
var cart = payload[0];
var rules = payload[1];
updateDismissedGifts(latestCart, cart, rules);
latestCart = cart;
return sync(cart, rules).then(function (changed) {
return fetchCart().then(function (nextCart) {
latestCart = nextCart;
var gifts = (nextCart.items || []).filter(function (item) {
return item.properties && String(item.properties[GIFT_FLAG] || '') === 'true';
});
applyGiftGuards(nextCart);
renderFloating(gifts);
if (changed) refreshTheme();
});
});
}).catch(function () {})
.finally(function () {
syncRunning = false;
if (syncPending) {
syncPending = false;
runSync();
}
});
}

['cart:updated', 'cart:refresh', 'cart:change', 'cart-items-added', 'CartDrawer:AfterItemAdded', 'shopify:cart:updated', 'on:cart:add'].forEach(function (eventName) {
document.addEventListener(eventName, function () { setTimeout(runSync, 120); });
});

document.addEventListener('click', function (event) {
var target = event.target;
if (!(target instanceof Element)) return;

var selector = target.closest("quantity-selector-component[data-upsale-bxgy-locked='true']");
if (!selector) return;

if (target.closest('.quantity-button')) {
event.preventDefault();
event.stopPropagation();
showToast('Free gift');
}
}, true);

document.addEventListener('input', function (event) {
var target = event.target;
if (!(target instanceof HTMLInputElement)) return;

var selector = target.closest("quantity-selector-component[data-upsale-bxgy-locked='true']");
if (!selector) return;

event.preventDefault();
target.value = selector.dataset.lockedQuantity || target.value;
}, true);

document.addEventListener('keydown', function (event) {
var target = event.target;
if (!(target instanceof HTMLInputElement)) return;

var selector = target.closest("quantity-selector-component[data-upsale-bxgy-locked='true']");
if (!selector) return;

event.preventDefault();
}, true);

var originalFetch = window.fetch;
window.fetch = function (input) {
var request = originalFetch.apply(this, arguments);
var url = typeof input === 'string' ? input : (input && input.url) || '';
if (/\/cart\/(add|change|update|clear)(\.js)?/.test(url)) {
request.then(function () { setTimeout(runSync, 100); }).catch(function () {});
}
return request;
};

var xhrOpen = XMLHttpRequest.prototype.open;
XMLHttpRequest.prototype.open = function (method, url) {
if (typeof url === 'string' && /\/cart\/(add|change|update|clear)(\.js)?/.test(url)) {
this.addEventListener('load', function () { setTimeout(runSync, 100); });
}
return xhrOpen.apply(this, arguments);
};

setTimeout(function () {
applyGiftGuards(latestCart);
}, 120);

runSync();
})();
</script>

{% schema %}
{
"name": "Gift Notification",
"target": "body",
"settings": [
{
"type": "text",
"id": "api_base",
"label": "App URL",
"default": "https://doomling-app-navy.vercel.app"
},
{
"type": "text",
"id": "toast_title",
"label": "Toast title",
"default": "Free gift added!"
},
{
"type": "text",
"id": "banner_title",
"label": "Floating banner title",
"default": "Your free gift is in the cart"
}
]
}
{% endschema %}
