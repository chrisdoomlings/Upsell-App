{% liquid
assign upsell_dom_id = 'upsale-root-' | append: block.id
%}

<div
id="{{ upsell_dom_id }}"
class="upsale-upsell-widget"
data-upsale-upsell-root
data-product-id="{{ product.id }}"
data-shop="{{ shop.permanent_domain }}"
data-currency="{{ shop.currency }}"
hidden
>
<style>
#{{ upsell_dom_id }} {
margin: 2rem 0 0;
font-family: var(--font-body--family, inherit);
color: rgb(var(--color-foreground, 17 24 39));
}

#{{ upsell_dom_id }} .upsale-upsell-panel {
border-top: 1px solid rgb(var(--color-foreground, 17 24 39) / 0.12);
padding-top: 2rem;
}

#{{ upsell_dom_id }} .upsale-upsell-heading {
display: flex;
align-items: baseline;
justify-content: space-between;
gap: 1rem;
margin-bottom: 1.25rem;
}

#{{ upsell_dom_id }} .upsale-upsell-controls {
display: none;
align-items: center;
gap: 0.5rem;
}

#{{ upsell_dom_id }} .upsale-upsell-controls[data-active="true"] {
display: inline-flex;
}

#{{ upsell_dom_id }} .upsale-upsell-arrow {
appearance: none;
border: 1px solid rgb(var(--color-foreground, 17 24 39) / 0.18);
width: 2.25rem;
height: 2.25rem;
display: inline-flex;
align-items: center;
justify-content: center;
border-radius: 999px;
background: rgb(var(--color-background, 255 255 255));
color: rgb(var(--color-foreground, 17 24 39));
cursor: pointer;
transition: background-color 0.2s ease, opacity 0.2s ease, border-color 0.2s ease;
}

#{{ upsell_dom_id }} .upsale-upsell-arrow:hover {
background: rgb(var(--color-foreground, 17 24 39) / 0.06);
border-color: rgb(var(--color-foreground, 17 24 39) / 0.35);
}

#{{ upsell_dom_id }} .upsale-upsell-arrow[disabled] {
opacity: 0.35;
cursor: default;
}

#{{ upsell_dom_id }} .upsale-upsell-title {
margin: 0;
font-family: var(--font-heading--family, var(--font-body--family, inherit));
font-size: clamp(1.45rem, 1.65vw, 1.8rem);
line-height: 1.08;
font-weight: 600;
color: rgb(var(--color-foreground, 17 24 39));
}

#{{ upsell_dom_id }} .upsale-upsell-track {
display: flex;
gap: 1.5rem;
overflow-x: auto;
scroll-snap-type: x mandatory;
scrollbar-width: none;
-ms-overflow-style: none;
scroll-behavior: smooth;
padding-bottom: 0.25rem;
}

#{{ upsell_dom_id }} .upsale-upsell-track::-webkit-scrollbar {
display: none;
}

#{{ upsell_dom_id }} .upsale-upsell-list {
display: contents;
}

#{{ upsell_dom_id }} .upsale-upsell-item {
position: relative;
display: flex;
flex-direction: column;
gap: 1rem;
min-width: 0;
flex: 0 0 calc(33.333% - 1rem);
scroll-snap-align: start;
}

#{{ upsell_dom_id }} .upsale-upsell-item-link {
position: absolute;
inset: 0;
z-index: 1;
}

#{{ upsell_dom_id }} .upsale-upsell-media {
width: 100%;
aspect-ratio: 1;
border-radius: 1.8rem;
overflow: hidden;
background: transparent;
transition: transform 0.25s ease;
}

#{{ upsell_dom_id }} .upsale-upsell-media img {
width: 100%;
height: 100%;
object-fit: cover;
display: block;
}

#{{ upsell_dom_id }} .upsale-upsell-placeholder {
width: 100%;
height: 100%;
border-radius: inherit;
background:
linear-gradient(
135deg,
rgb(var(--color-foreground, 17 24 39) / 0.04),
rgb(var(--color-foreground, 17 24 39) / 0.09)
);
}

#{{ upsell_dom_id }} .upsale-upsell-item:hover .upsale-upsell-media {
transform: translateY(-1px);
}

#{{ upsell_dom_id }} .upsale-upsell-content {
min-width: 0;
display: grid;
gap: 0.65rem;
align-items: var(--content-alignment, flex-start);
}

#{{ upsell_dom_id }} .upsale-upsell-topline {
display: grid;
gap: 0.4rem;
}

#{{ upsell_dom_id }} .upsale-upsell-product-title {
margin: 0;
position: relative;
z-index: 2;
color: rgb(var(--color-foreground, 17 24 39));
font-family: var(--font-pcard-title--family, var(--font-heading--family, var(--font-body--family, inherit)));
font-weight: var(--font-pcard-title--weight, 600);
font-style: var(--font-pcard-title--style, normal);
font-size: var(--font-pcard-title--size, 1rem);
line-height: 1.45;
color: rgb(var(--color-foreground, 17 24 39));
}

#{{ upsell_dom_id }} .upsale-upsell-price-row {
display: flex;
flex-wrap: wrap;
align-items: center;
gap: 0.55rem 0.75rem;
}

#{{ upsell_dom_id }} .upsale-upsell-price {
font-size: 1rem;
font-weight: 700;
color: rgb(var(--color-foreground, 17 24 39));
}

#{{ upsell_dom_id }} .upsale-upsell-compare {
font-size: 0.95rem;
color: rgb(var(--color-foreground, 17 24 39) / 0.48);
text-decoration: line-through;
}

#{{ upsell_dom_id }} .upsale-upsell-badge {
display: inline-flex;
align-items: center;
min-height: 1.85rem;
padding: 0.15rem 0.7rem;
border-radius: 999px;
background: rgb(var(--color-button, 17 24 39));
color: rgb(var(--color-button-text, 255 255 255));
font-size: 0.7rem;
font-weight: 700;
letter-spacing: 0.04em;
text-transform: uppercase;
}

#{{ upsell_dom_id }} .upsale-upsell-custom-badge {
display: inline-flex;
align-items: center;
min-height: 1.8rem;
padding: 0.12rem 0.65rem;
border-radius: 999px;
background: rgb(var(--color-foreground, 17 24 39) / 0.08);
color: rgb(var(--color-foreground, 17 24 39) / 0.78);
font-size: 0.7rem;
font-weight: 700;
letter-spacing: 0.04em;
text-transform: uppercase;
}

#{{ upsell_dom_id }} .upsale-upsell-actions {
display: flex;
flex-wrap: wrap;
align-items: center;
gap: 0.7rem;
position: relative;
z-index: 2;
}

#{{ upsell_dom_id }} .upsale-upsell-actions > * {
position: relative;
z-index: 3;
}

#{{ upsell_dom_id }} .upsale-upsell-button,
#{{ upsell_dom_id }} .upsale-upsell-link {
appearance: none;
border: none;
border-radius: 999px;
min-height: 2.7rem;
padding: 0 1.1rem;
display: inline-flex;
align-items: center;
justify-content: center;
gap: 0.45rem;
text-decoration: none;
cursor: pointer;
font: inherit;
font-size: 0.9rem;
font-weight: 600;
transition: transform 0.2s ease, opacity 0.2s ease, background-color 0.2s ease;
}

#{{ upsell_dom_id }} .upsale-upsell-button {
background: rgb(var(--color-button, 17 24 39));
color: rgb(var(--color-button-text, 255 255 255));
}

#{{ upsell_dom_id }} .upsale-upsell-link {
background: transparent;
color: rgb(var(--color-foreground, 17 24 39));
border: 1px solid rgb(var(--color-foreground, 17 24 39) / 0.14);
}

#{{ upsell_dom_id }} .upsale-upsell-button:hover,
#{{ upsell_dom_id }} .upsale-upsell-link:hover {
transform: translateY(-1px);
}

#{{ upsell_dom_id }} .upsale-upsell-button:disabled {
opacity: 0.55;
cursor: wait;
transform: none;
}

#{{ upsell_dom_id }} .upsale-upsell-added {
display: none;
align-items: center;
gap: 0.45rem;
font-size: 0.9rem;
font-weight: 600;
color: rgb(var(--color-foreground, 17 24 39));
}

#{{ upsell_dom_id }} .upsale-upsell-added svg {
width: 1rem;
height: 1rem;
color: rgb(var(--color-button, 17 24 39));
}

@media (max-width: 767px) {
#{{ upsell_dom_id }} {
margin-top: 1.6rem;
}

#{{ upsell_dom_id }} .upsale-upsell-panel {
padding-top: 1.5rem;
}

#{{ upsell_dom_id }} .upsale-upsell-track {
gap: 1rem;
}

#{{ upsell_dom_id }} .upsale-upsell-item {
flex-basis: calc(82vw - 2rem);
}

#{{ upsell_dom_id }} .upsale-upsell-actions > * {
width: 100%;
}
}

@media (min-width: 768px) and (max-width: 1023px) {
#{{ upsell_dom_id }} .upsale-upsell-item {
flex-basis: calc(50% - 0.75rem);
}
}
</style>

<div class="upsale-upsell-panel">
<div class="upsale-upsell-heading">
<h3 class="upsale-upsell-title">{{ settings.header_text | default: 'More for you' }}</h3>
<div class="upsale-upsell-controls" data-upsale-controls data-active="false">
<button type="button" class="upsale-upsell-arrow" data-upsale-prev aria-label="Previous recommendations">
<svg viewBox="0 0 20 20" width="18" height="18" fill="none" aria-hidden="true"><path d="M11.5 5.5 7 10l4.5 4.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
</button>
<button type="button" class="upsale-upsell-arrow" data-upsale-next aria-label="Next recommendations">
<svg viewBox="0 0 20 20" width="18" height="18" fill="none" aria-hidden="true"><path d="M8.5 5.5 13 10l-4.5 4.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
</button>
</div>
</div>
<div class="upsale-upsell-track" data-upsale-track>
<div class="upsale-upsell-list" data-upsale-list></div>
</div>
</div>
</div>

<script>
(function () {
var root = document.getElementById('{{ upsell_dom_id }}');
if (!root) return;

var shop = root.dataset.shop;
var productId = root.dataset.productId;
var currency = root.dataset.currency;
var apiBase = 'https://doomling-app-navy.vercel.app';
var list = root.querySelector('[data-upsale-list]');
var trackEl = root.querySelector('[data-upsale-track]');
var controls = root.querySelector('[data-upsale-controls]');
var prevButton = root.querySelector('[data-upsale-prev]');
var nextButton = root.querySelector('[data-upsale-next]');

if (!shop || !productId || !list || !trackEl) return;

var formatMoney = function (value) {
var amount = Number(value || 0);
try {
return new Intl.NumberFormat(undefined, {
style: 'currency',
currency: currency || 'USD',
maximumFractionDigits: 2
}).format(amount);
} catch (error) {
return amount.toFixed(2);
}
};

var escapeHtml = function (value) {
return String(value || '')
.replace(/&/g, '&amp;')
.replace(/</g, '&lt;')
.replace(/>/g, '&gt;')
.replace(/"/g, '&quot;')
.replace(/'/g, '&#39;');
};

var track = function (ruleId, event) {
fetch(apiBase + '/api/track', {
method: 'POST',
headers: { 'Content-Type': 'application/json' },
body: JSON.stringify({ shop: shop, ruleId: ruleId, event: event })
}).catch(function () {});
};

var getCartSectionIds = function () {
var sections = [];
document.querySelectorAll('cart-items-component[data-section-id], cart-discount[data-section-id]').forEach(function (element) {
if (!(element instanceof HTMLElement)) return;
var sectionId = element.dataset.sectionId;
if (sectionId && sections.indexOf(sectionId) === -1) {
sections.push(sectionId);
}
});
return sections;
};

var dispatchCartUpdate = function (payload) {
document.dispatchEvent(new CustomEvent('cart:update', {
bubbles: true,
detail: {
resource: {},
sourceId: 'upsale-upsell-widget',
data: payload
}
}));
};

var getCartProductIds = function () {
return fetch('/cart.js', { headers: { Accept: 'application/json' } })
.then(function (response) { return response.ok ? response.json() : null; })
.then(function (cart) {
if (!cart || !Array.isArray(cart.items)) return [];
return cart.items
.map(function (item) { return String(item.product_id || ''); })
.filter(Boolean);
})
.catch(function () { return []; });
};

var updateControls = function () {
if (!(controls instanceof HTMLElement) || !(trackEl instanceof HTMLElement)) return;
var maxScroll = trackEl.scrollWidth - trackEl.clientWidth;
var active = maxScroll > 8;
controls.setAttribute('data-active', active ? 'true' : 'false');
if (prevButton instanceof HTMLButtonElement) {
prevButton.disabled = !active || trackEl.scrollLeft <= 8;
}
if (nextButton instanceof HTMLButtonElement) {
nextButton.disabled = !active || trackEl.scrollLeft >= maxScroll - 8;
}
};

var buildItem = function (upsell, variantId, ruleId) {
var item = document.createElement('article');
item.className = 'upsale-upsell-item';

var mediaHtml = upsell.image
? '<div class="upsale-upsell-media"><img src="' + escapeHtml(upsell.image) + '" alt="' + escapeHtml(upsell.title) + '"></div>'
: '<div class="upsale-upsell-media"><div class="upsale-upsell-placeholder"></div></div>';

var compareHtml = upsell.discountPercent > 0
? '<span class="upsale-upsell-compare">' + formatMoney(upsell.originalPrice) + '</span><span class="upsale-upsell-badge">Save ' + escapeHtml(upsell.discountPercent) + '%</span>'
: '';
var customBadgeHtml = upsell.badgeText
? '<span class="upsale-upsell-custom-badge">' + escapeHtml(upsell.badgeText) + '</span>'
: '';

var actionHtml = variantId
? '<button type="button" class="upsale-upsell-button" data-upsale-add>Add to cart</button>'
: '<a class="upsale-upsell-link" href="/products/' + escapeHtml(upsell.handle || '') + '">View product</a>';

item.innerHTML =
'<a class="upsale-upsell-item-link" href="/products/' + escapeHtml(upsell.handle || '') + '" aria-label="' + escapeHtml(upsell.title) + '"></a>' +
mediaHtml +
'<div class="upsale-upsell-content">' +
'<div class="upsale-upsell-topline">' +
customBadgeHtml +
'<p class="upsale-upsell-product-title">' + escapeHtml(upsell.title) + '</p>' +
'<div class="upsale-upsell-price-row">' +
'<span class="upsale-upsell-price">' + formatMoney(upsell.price) + '</span>' +
compareHtml +
'</div>' +
'</div>' +
'<div class="upsale-upsell-actions">' +
actionHtml +
'<span class="upsale-upsell-added" data-upsale-added>' +
'<svg viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M13.5 4.5 6.5 11.5 2.5 7.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>' +
'Added to cart' +
'</span>' +
'</div>' +
'</div>';

if (variantId) {
var button = item.querySelector('[data-upsale-add]');
var added = item.querySelector('[data-upsale-added]');
button.addEventListener('click', function () {
track(ruleId, 'click');
button.disabled = true;
button.textContent = 'Adding...';

var sectionIds = getCartSectionIds();
var formData = new FormData();
formData.append('id', String(variantId));
formData.append('quantity', '1');
formData.append('properties[_upsale]', 'true');
formData.append('properties[_upsale_rule_id]', String(ruleId));
if (sectionIds.length) {
formData.append('sections', sectionIds.join(','));
}

fetch('/cart/add.js', {
method: 'POST',
headers: {
Accept: 'text/html'
},
body: formData
})
.then(function (response) {
return response.json().then(function (data) {
if (!response.ok || data.status) throw new Error('add_failed');
return data;
});
})
.then(function (data) {
track(ruleId, 'added');
button.hidden = true;
added.style.display = 'inline-flex';
dispatchCartUpdate({
source: 'upsale-upsell-widget',
itemCount: 1,
isIncremental: true,
variantId: String(variantId),
sections: data.sections || {}
});
document.dispatchEvent(new CustomEvent('cart:refresh'));
document.dispatchEvent(new CustomEvent('cart:updated'));
})
.catch(function () {
button.disabled = false;
button.textContent = 'Add to cart';
});
});
}

return item;
};

var resolveVariantId = function (upsell) {
if (!upsell.handle) return Promise.resolve(null);
return fetch('/products/' + upsell.handle + '.js')
.then(function (response) { return response.ok ? response.json() : null; })
.then(function (product) {
return product && product.variants && product.variants[0] && product.variants[0].id
? product.variants[0].id
: null;
})
.catch(function () { return null; });
};

if (prevButton instanceof HTMLButtonElement) {
prevButton.addEventListener('click', function () {
trackEl.scrollBy({ left: -Math.max(trackEl.clientWidth * 0.85, 220), behavior: 'smooth' });
});
}
if (nextButton instanceof HTMLButtonElement) {
nextButton.addEventListener('click', function () {
trackEl.scrollBy({ left: Math.max(trackEl.clientWidth * 0.85, 220), behavior: 'smooth' });
});
}
trackEl.addEventListener('scroll', updateControls, { passive: true });
window.addEventListener('resize', updateControls);

Promise.all([
fetch(apiBase + '/api/upsell?shop=' + encodeURIComponent(shop) + '&product_id=' + encodeURIComponent(productId))
.then(function (response) { return response.ok ? response.json() : { upsells: [] }; })
.catch(function () { return { upsells: [] }; }),
getCartProductIds()
]).then(function (results) {
var data = results[0];
var cartProductIds = results[1] || [];
var upsells = data && Array.isArray(data.upsells) ? data.upsells : [];
upsells = upsells.filter(function (upsell) {
return cartProductIds.indexOf(String(upsell.productId || '')) === -1;
});
if (!upsells.length) return;

var ruleId = upsells[0].ruleId;
return Promise.all(upsells.map(function (upsell) {
return resolveVariantId(upsell).then(function (variantId) {
list.appendChild(buildItem(upsell, variantId, ruleId));
});
})).then(function () {
root.hidden = false;
requestAnimationFrame(function () {
requestAnimationFrame(updateControls);
});
track(ruleId, 'view');
});
})
.catch(function () {});
})();
</script>

{% schema %}
{
"name": "Upsell Widget",
"target": "section",
"settings": [
{
"type": "text",
"id": "eyebrow_text",
"label": "Eyebrow text",
"default": "You may also like"
},
{
"type": "text",
"id": "header_text",
"label": "Heading",
"default": "More for you"
}
]
}
{% endschema %}
