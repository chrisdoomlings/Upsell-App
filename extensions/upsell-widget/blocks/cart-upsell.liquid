{% comment %} Upsale - Cart Recommendations {% endcomment %}

{% assign cart_product_ids = '' %}
{% for item in cart.items %}
{% assign cart_product_ids = cart_product_ids | append: item.product_id | append: ',' %}
{% endfor %}

<div
id="upsale-cart-root"
data-shop="{{ shop.permanent_domain }}"
data-currency="{{ shop.currency }}"
data-product-ids="{{ cart_product_ids }}"
style="display:none; margin: 1.5rem 0;"
>

<style>
#upsale-cart-root * { box-sizing: border-box; }
#upsale-cart-card {
border-radius: 12px;
border: 1px solid #e4e5e7;
overflow: hidden;
background: #fff;
font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
}
#upsale-cart-header {
background: #f9fafb;
border-bottom: 1px solid #e4e5e7;
padding: 0.75rem 1.25rem;
display: flex;
align-items: center;
gap: 0.5rem;
}
#upsale-cart-header-text {
font-size: 0.85rem;
font-weight: 700;
color: #1a1a1a;
text-transform: uppercase;
letter-spacing: 0.04em;
}
#upsale-cart-body {
padding: 1.25rem;
display: flex;
align-items: center;
gap: 1rem;
}
#upsale-cart-img {
width: 80px; height: 80px;
object-fit: cover;
border-radius: 8px;
flex-shrink: 0;
display: none;
}
#upsale-cart-img-placeholder {
width: 80px; height: 80px;
background: #f1f1f1;
border-radius: 8px;
flex-shrink: 0;
}
#upsale-cart-info { flex: 1; min-width: 0; }
#upsale-cart-label { margin: 0 0 0.2rem; font-size: 0.78rem; color: #6d7175; }
#upsale-cart-title { margin: 0 0 0.4rem; font-size: 0.95rem; font-weight: 600; color: #1a1a1a; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
#upsale-cart-prices { display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap; }
#upsale-cart-price { font-size: 1rem; font-weight: 700; color: #008060; }
#upsale-cart-original { font-size: 0.85rem; color: #9ca3af; text-decoration: line-through; display: none; }
#upsale-cart-badge { font-size: 0.7rem; font-weight: 700; background: #fef3c7; color: #92400e; padding: 0.15rem 0.5rem; border-radius: 20px; display: none; }
#upsale-cart-btn {
flex-shrink: 0;
padding: 0.7rem 1.25rem;
background: #008060;
color: #fff;
border: none;
border-radius: 8px;
font-size: 0.875rem;
font-weight: 600;
cursor: pointer;
white-space: nowrap;
transition: background 0.15s;
}
#upsale-cart-btn:hover { background: #006e52; }
#upsale-cart-btn:disabled { background: #9ca3af; cursor: not-allowed; }
#upsale-cart-added {
display: none;
flex-shrink: 0;
padding: 0.7rem 1.25rem;
background: #e3f1df;
color: #1a6b3c;
border-radius: 8px;
font-size: 0.875rem;
font-weight: 600;
}
#upsale-cart-in-cart-note {
display: none;
font-size: 0.75rem;
font-weight: 600;
color: #008060;
margin: 0 0 0.3rem;
}
</style>

<div id="upsale-cart-card">
<div id="upsale-cart-header">
<svg width="14" height="14" viewBox="0 0 20 20" fill="#008060"><path d="M10 1l2.39 4.84 5.34.78-3.87 3.77.91 5.32L10 13.27l-4.77 2.44.91-5.32L2.27 6.62l5.34-.78z"/></svg>
<span id="upsale-cart-header-text">{{ settings.header_text | default: 'Complete your order' }}</span>
</div>
<div id="upsale-cart-body">
<img id="upsale-cart-img" src="" alt="" width="80" height="80" />
<div id="upsale-cart-img-placeholder"></div>
<div id="upsale-cart-info">
<p id="upsale-cart-in-cart-note">Already in your cart</p>
<p id="upsale-cart-label"></p>
<p id="upsale-cart-title"></p>
<div id="upsale-cart-prices">
<span id="upsale-cart-price"></span>
<span id="upsale-cart-original"></span>
<span id="upsale-cart-badge"></span>
</div>
</div>
<button id="upsale-cart-btn">Add to cart</button>
<div id="upsale-cart-added">Added!</div>
</div>
</div>

</div>

<script>
(function () {
var root = document.getElementById('upsale-cart-root');
if (!root) return;

var shop = root.dataset.shop;
var currency = root.dataset.currency;
var apiBase = 'https://upseller-app.vercel.app';
var refreshTimer = null;
var activeRequest = 0;

if (!shop) return;

var fmt = function (n) {
try {
return new Intl.NumberFormat('en-US', { style: 'currency', currency: currency || 'USD' }).format(n);
} catch (e) {
return currency + ' ' + parseFloat(n).toFixed(2);
}
};

var getCartSectionIds = function () {
var sections = [];
document.querySelectorAll('cart-items-component[data-section-id], cart-discount[data-section-id]').forEach(function (element) {
if (!(element instanceof HTMLElement)) return;
var sectionId = element.dataset.sectionId;
if (sectionId && sections.indexOf(sectionId) === -1) {
sections.push(sectionId);
}
});
return sections;
};

var dispatchCartUpdate = function (payload) {
document.dispatchEvent(new CustomEvent('cart:update', {
bubbles: true,
detail: {
resource: {},
sourceId: 'upsale-cart-widget',
data: payload || {}
}
}));
};

var postCart = function (path, payload) {
var body = Object.assign({}, payload || {});
var sections = getCartSectionIds();
if (sections.length) {
body.sections = sections;
body.sections_url = window.location.pathname;
}

return fetch(path, {
method: 'POST',
headers: {
'Content-Type': 'application/json',
Accept: 'application/json'
},
body: JSON.stringify(body)
}).then(function (response) {
return response.json().then(function (data) {
if (!response.ok || (data && data.status)) throw new Error('cart_request_failed');
return data;
});
});
};

var track = function (ruleId, event) {
fetch(apiBase + '/api/track', {
method: 'POST',
headers: { 'Content-Type': 'application/json' },
body: JSON.stringify({ shop: shop, ruleId: ruleId, event: event })
}).catch(function () {});
};

var resetOfferUi = function () {
var label = document.getElementById('upsale-cart-label');
var title = document.getElementById('upsale-cart-title');
var price = document.getElementById('upsale-cart-price');
var original = document.getElementById('upsale-cart-original');
var badge = document.getElementById('upsale-cart-badge');
var img = document.getElementById('upsale-cart-img');
var placeholder = document.getElementById('upsale-cart-img-placeholder');
var btn = document.getElementById('upsale-cart-btn');
var added = document.getElementById('upsale-cart-added');
var inCartNote = document.getElementById('upsale-cart-in-cart-note');

if (label) label.textContent = '';
if (title) title.textContent = '';
if (price) price.textContent = '';
if (original) {
original.textContent = '';
original.style.display = 'none';
}
if (badge) {
badge.textContent = '';
badge.style.display = 'none';
}
if (img) {
img.src = '';
img.alt = '';
img.style.display = 'none';
}
if (placeholder) placeholder.style.display = 'block';
if (btn) {
btn.disabled = false;
btn.style.display = '';
btn.textContent = 'Add to cart';
btn.onclick = null;
}
if (added) added.style.display = 'none';
if (inCartNote) inCartNote.style.display = 'none';
root.style.display = 'none';
};

var resolveVariantId = function (handle) {
if (!handle) return Promise.resolve(null);
return fetch('/products/' + handle + '.js')
.then(function (response) { return response.ok ? response.json() : null; })
.then(function (product) {
return product && product.variants && product.variants[0] && product.variants[0].id
? product.variants[0].id
: null;
})
.catch(function () { return null; });
};

var renderOffer = function (offer, cartProductIds) {
var label = document.getElementById('upsale-cart-label');
var title = document.getElementById('upsale-cart-title');
var price = document.getElementById('upsale-cart-price');
var original = document.getElementById('upsale-cart-original');
var badge = document.getElementById('upsale-cart-badge');
var img = document.getElementById('upsale-cart-img');
var placeholder = document.getElementById('upsale-cart-img-placeholder');
var btn = document.getElementById('upsale-cart-btn');
var added = document.getElementById('upsale-cart-added');
var inCartNote = document.getElementById('upsale-cart-in-cart-note');
var inCart = cartProductIds.indexOf(String(offer.productId || '')) !== -1;

if (label) label.textContent = offer.message || 'You might also like';
if (title) title.textContent = offer.title || '';
if (price) price.textContent = fmt(offer.price);

if (original) {
if (offer.discountPercent > 0) {
original.textContent = fmt(offer.originalPrice);
original.style.display = 'inline';
} else {
original.textContent = '';
original.style.display = 'none';
}
}

if (badge) {
if (offer.discountPercent > 0) {
badge.textContent = offer.discountPercent + '% OFF';
badge.style.display = 'inline';
} else {
badge.textContent = '';
badge.style.display = 'none';
}
}

if (img && placeholder) {
if (offer.image) {
img.src = offer.image;
img.alt = offer.title || '';
img.style.display = 'block';
placeholder.style.display = 'none';
} else {
img.src = '';
img.alt = '';
img.style.display = 'none';
placeholder.style.display = 'block';
}
}

if (inCartNote) inCartNote.style.display = inCart ? 'block' : 'none';
if (added) added.style.display = 'none';
root.style.display = 'block';
track(offer.ruleId, 'view');

return resolveVariantId(offer.handle).then(function (variantId) {
if (!btn) return null;

btn.disabled = false;
btn.style.display = '';
btn.textContent = variantId ? (inCart ? 'Add again' : 'Add to cart') : 'View product';
btn.onclick = function () {
if (!variantId) {
window.location.href = '/products/' + offer.handle;
return;
}

track(offer.ruleId, 'click');
btn.disabled = true;
btn.textContent = 'Adding...';

postCart('/cart/add.js', {
id: variantId,
quantity: 1,
properties: {
_upsale: 'true',
_upsale_rule_id: String(offer.ruleId)
}
})
.then(function (data) {
track(offer.ruleId, 'added');
btn.style.display = 'none';
if (added) added.style.display = 'block';
dispatchCartUpdate({
source: 'upsale-cart-widget',
itemCount: 1,
isIncremental: true,
variantId: String(variantId),
sections: (data && data.sections) || {}
});
document.dispatchEvent(new CustomEvent('cart:refresh'));
document.dispatchEvent(new CustomEvent('cart:updated'));
scheduleRefresh();
})
.catch(function () {
btn.disabled = false;
btn.textContent = inCart ? 'Add again' : 'Add to cart';
});
};

return null;
});
};

var loadOffer = function () {
var requestId = ++activeRequest;

return fetch('/cart.js', { headers: { Accept: 'application/json' }, cache: 'no-store' })
.then(function (response) { return response.ok ? response.json() : null; })
.then(function (cart) {
if (requestId !== activeRequest || !cart || !Array.isArray(cart.items) || cart.items.length === 0) {
resetOfferUi();
return null;
}

var cartProductIds = cart.items
.map(function (item) { return String(item.product_id || ''); })
.filter(Boolean);

var uniqueIds = [];
cartProductIds.forEach(function (id) {
if (uniqueIds.indexOf(id) === -1) uniqueIds.push(id);
});

var tryNext = function (index) {
if (requestId !== activeRequest || index >= uniqueIds.length) {
resetOfferUi();
return null;
}

return fetch(apiBase + '/api/upsell?shop=' + encodeURIComponent(shop) + '&product_id=' + encodeURIComponent(uniqueIds[index]))
.then(function (response) { return response.ok ? response.json() : { upsells: [] }; })
.then(function (data) {
var upsell = data && Array.isArray(data.upsells) ? data.upsells[0] : null;
if (!upsell) return tryNext(index + 1);
return renderOffer(upsell, cartProductIds);
})
.catch(function () {
return tryNext(index + 1);
});
};

return tryNext(0);
})
.catch(function () {
resetOfferUi();
return null;
});
};

function scheduleRefresh() {
if (refreshTimer) window.clearTimeout(refreshTimer);
refreshTimer = window.setTimeout(function () {
loadOffer();
}, 80);
}

['cart:updated', 'cart:refresh', 'cart:update', 'cart:change', 'cart-items-added', 'CartDrawer:AfterItemAdded', 'shopify:cart:updated', 'on:cart:add'].forEach(function (eventName) {
document.addEventListener(eventName, scheduleRefresh);
});

if (document.readyState === 'loading') {
document.addEventListener('DOMContentLoaded', loadOffer, { once: true });
} else {
loadOffer();
}
})();
</script>

{% schema %}
{
"name": "Cart Upsell",
"target": "section",
"settings": [
{
"type": "text",
"id": "header_text",
"label": "Header label",
"default": "Complete your order"
}
]
}
{% endschema %}
